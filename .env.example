# Neon Postgres Connection String
# Zu finden unter: neon.tech → Dein Projekt → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Geheimer Schlüssel für die Login-Sessions (langer Zufallsstring)
JWT_SECRET=langer-zufallsstring

# Admin-Passwort für den /admin Bereich
ADMIN_PASSWORD=dein-geheimes-passwort

# --- Push-Benachrichtigungen (Web Push / VAPID) ---
# Einmalig erzeugen mit:  npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=dein-vapid-public-key
VAPID_PRIVATE_KEY=dein-vapid-private-key

# Schützt den Benachrichtigungs-Endpoint /api/notify.
# Der externe Cron-Dienst (z. B. cron-job.org) muss diesen Wert als
#   Authorization: Bearer <CRON_SECRET>   mitschicken.
CRON_SECRET=langer-zufallsstring
